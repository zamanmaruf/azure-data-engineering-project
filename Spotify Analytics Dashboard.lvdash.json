{
  "datasets": [
    {
      "name": "5c54c55c",
      "displayName": "top_tracks",
      "queryLines": [
        "SELECT track_name, artist_name, album_name, total_streams\n",
        "FROM main.gold.gold_top_tracks\n",
        "ORDER BY total_streams DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "bf7dfd85",
      "displayName": "top_artists",
      "queryLines": [
        "SELECT artist_name, total_streams\n",
        "FROM main.gold.gold_top_artists\n",
        "ORDER BY total_streams DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "a215056e",
      "displayName": "monthly_streams",
      "queryLines": [
        "SELECT year, month, total_streams,\n",
        "  CONCAT(year, '-', LPAD(CAST(month AS STRING), 2, '0')) as month_label\n",
        "FROM main.gold.gold_monthly_streams\n",
        "ORDER BY year, month"
      ]
    },
    {
      "name": "77996f46",
      "displayName": "device_streams",
      "queryLines": [
        "SELECT device_type, COUNT(*) as total_streams\n",
        "FROM spotify_catalog.silver.fact_streams\n",
        "GROUP BY device_type\n",
        "ORDER BY total_streams DESC"
      ]
    }
  ],
